<odoo>
    <data>
        <record id="view_res_config_settings_judicial_blockchain" model="ir.ui.view">
            <field name="name">res.config.settings.view.form.judicial.blockchain</field>
            <field name="model">res.config.settings</field>
            <field name="inherit_id" ref="base_setup.res_config_settings_view_form"/>
            <field name="arch" type="xml">
                <xpath expr="//form" position="inside">
                    <app string="Judicial Blockchain" name="judicial_blockchain_settings">
                        <block title="Configuración Polygon / EVM">
                            <setting string="RPC URL">
                                <field name="judicial_polygon_rpc_url" placeholder="https://rpc-amoy.polygon.technology"/>
                            </setting>
                            <setting string="Chain ID">
                                <field name="judicial_chain_id"/>
                            </setting>
                            <setting string="Private Key">
                                <field name="judicial_private_key" password="True"/>
                            </setting>
                            <setting string="Contract Address">
                                <field name="judicial_contract_address"/>
                            </setting>
                            <setting string="Contract ABI JSON">
                                <field name="judicial_contract_abi" widget="text"/>
                            </setting>
                        </block>
                    </app>
                </xpath>
            </field>
        </record>
    </data>
</odoo>
