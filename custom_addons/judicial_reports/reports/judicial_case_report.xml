<odoo>
    <data>

        <record id="action_report_judicial_case" model="ir.actions.report">
            <field name="name">Reporte de Expediente</field>
            <field name="model">judicial.case</field>
            <field name="report_type">qweb-pdf</field>
            <field name="report_name">judicial_reports.case_report_template</field>
            <field name="report_file">judicial_reports.case_report_template</field>
            <field name="print_report_name">'Expediente - %s' % object.name</field>
        </record>

        <template id="case_report_template">
            <t t-call="web.html_container">
                <t t-foreach="docs" t-as="doc">
                    <div style="font-family: 'Helvetica Neue', Helvetica, Arial, sans-serif;
                                color: #2c2c2c; padding: 24px; margin: 0;">


                        <div style="background: #1a3a5c; color: white;
                                    padding: 20px 24px; border-radius: 6px;
                                    margin-bottom: 20px;">
                            <table style="width: 100%; border-collapse: collapse;">
                                <tr>
                                    <td style="vertical-align: middle;">
                                        <div style="font-size: 20px; font-weight: 700; letter-spacing: 0.5px;">
                                            EXPEDIENTE JUDICIAL
                                        </div>
                                        <div style="font-size: 12px; margin-top: 4px; color: #aac4e0;">
                                            Sistema de Gestion Judicial · Protegido por Blockchain
                                        </div>
                                    </td>
                                    <td style="text-align: right; vertical-align: middle;">
                                        <div style="font-size: 24px; font-weight: 800;
                                                    border: 2px solid rgba(255,255,255,0.4);
                                                    padding: 8px 16px; border-radius: 4px;
                                                    display: inline-block;">
                                            <span t-field="doc.name"/>
                                        </div>
                                    </td>
                                </tr>
                            </table>
                        </div>


                        <table style="width: 100%; border-collapse: collapse; margin-bottom: 20px;">
                            <tr>
                                <td style="width: 50%; vertical-align: top; padding-right: 10px;">
                                    <div style="background: #f7f9fc; border: 1px solid #dde3ed;
                                                border-radius: 6px; padding: 14px;">
                                        <div style="font-size: 11px; font-weight: 700; color: #2d6a9f;
                                                    text-transform: uppercase; letter-spacing: 0.8px;
                                                    border-bottom: 2px solid #2d6a9f;
                                                    padding-bottom: 6px; margin-bottom: 12px;">
                                            Datos del Expediente
                                        </div>
                                        <table style="width: 100%; border-collapse: collapse; font-size: 11px;">
                                            <tr>
                                                <td style="padding: 5px 0; color: #555; width: 40%;">Titulo</td>
                                                <td style="padding: 5px 0; font-weight: 600; color: #1a1a1a;">
                                                    <span t-field="doc.title"/>
                                                </td>
                                            </tr>
                                            <tr style="background: #eef2f8;">
                                                <td style="padding: 5px 6px; color: #555;">Parte procesal</td>
                                                <td style="padding: 5px 6px; font-weight: 600; color: #1a1a1a;">
                                                    <span t-field="doc.partner_id.name"/>
                                                </td>
                                            </tr>
                                            <tr>
                                                <td style="padding: 5px 0; color: #555;">Responsable</td>
                                                <td style="padding: 5px 0; font-weight: 600; color: #1a1a1a;">
                                                    <span t-field="doc.assigned_user_id.name"/>
                                                </td>
                                            </tr>
                                            <tr style="background: #eef2f8;">
                                                <td style="padding: 5px 6px; color: #555;">Estado</td>
                                                <td style="padding: 5px 6px;">
                                                    <span style="background: #2d6a9f; color: white;
                                                                 padding: 2px 10px; border-radius: 12px;
                                                                 font-size: 10px; font-weight: 700;">
                                                        <span t-field="doc.state"/>
                                                    </span>
                                                </td>
                                            </tr>
                                        </table>
                                    </div>
                                </td>

                                <td style="width: 50%; vertical-align: top; padding-left: 10px;">
                                    <div style="background: #f0f7f0; border: 1px solid #c3dfc3;
                                                border-radius: 6px; padding: 14px;">
                                        <div style="font-size: 11px; font-weight: 700; color: #2e7d32;
                                                    text-transform: uppercase; letter-spacing: 0.8px;
                                                    border-bottom: 2px solid #2e7d32;
                                                    padding-bottom: 6px; margin-bottom: 12px;">
                                            Trazabilidad Blockchain
                                        </div>
                                        <table style="width: 100%; border-collapse: collapse; font-size: 10px;">
                                            <tr>
                                                <td style="padding: 5px 0; color: #555; width: 38%; vertical-align: top;">
                                                    Hash SHA-256
                                                </td>
                                                <td style="padding: 5px 0; font-family: monospace;
                                                           word-break: break-all; font-size: 8.5px; color: #222;">
                                                    <t t-esc="doc.active_document_hash or '—'"/>
                                                </td>
                                            </tr>
                                            <tr style="background: #e8f5e9;">
                                                <td style="padding: 5px 6px; color: #555; vertical-align: top;">TX Hash</td>
                                                <td style="padding: 5px 6px; font-family: monospace;
                                                           word-break: break-all; font-size: 8.5px; color: #222;">
                                                    <t t-esc="doc.blockchain_tx_hash or '—'"/>
                                                </td>
                                            </tr>
                                            <tr>
                                                <td style="padding: 5px 0; color: #555;">Fecha anclaje</td>
                                                <td style="padding: 5px 0; font-weight: 700; color: #2e7d32;">
                                                    <t t-esc="doc.blockchain_anchor_at or '—'"/>
                                                </td>
                                            </tr>
                                        </table>
                                    </div>
                                </td>
                            </tr>
                        </table>


                        <t t-if="doc.description">
                            <div style="background: #fffef5; border-left: 4px solid #f0a500;
                                        padding: 12px 16px; border-radius: 0 6px 6px 0;
                                        margin-bottom: 20px; font-size: 11px;">
                                <div style="font-weight: 700; color: #b37a00; margin-bottom: 6px;
                                            text-transform: uppercase; font-size: 10px; letter-spacing: 0.6px;">
                                    Descripcion
                                </div>
                                <p style="margin: 0; line-height: 1.6; color: #2c2c2c;" t-esc="doc.description"/>
                            </div>
                        </t>


                        <div style="font-size: 11px; font-weight: 700; color: #1a3a5c;
                                    text-transform: uppercase; letter-spacing: 0.8px;
                                    margin-bottom: 10px;">
                            Documentos del Expediente
                        </div>
                        <table style="width: 100%; border-collapse: collapse; font-size: 10px;
                                      border: 1px solid #dde3ed;">
                            <thead>
                                <tr style="background: #1a3a5c; color: white;">
                                    <th style="padding: 8px 10px; text-align: left; font-weight: 600; color: white;">#</th>
                                    <th style="padding: 8px 10px; text-align: left; font-weight: 600; color: white;">Nombre</th>
                                    <th style="padding: 8px 10px; text-align: left; font-weight: 600; color: white;">Tipo</th>
                                    <th style="padding: 8px 10px; text-align: left; font-weight: 600; color: white;">SHA-256</th>
                                </tr>
                            </thead>
                            <tbody>
                                <tr t-foreach="doc.document_ids" t-as="line"
                                    t-attf-style="background: {{ '#f7f9fc' if line_index % 2 == 0 else 'white' }}; border-bottom: 1px solid #eee;">
                                    <td style="padding: 7px 10px; color: #666;">
                                        <t t-esc="line_index + 1"/>
                                    </td>
                                    <td style="padding: 7px 10px; font-weight: 600; color: #1a1a1a;">
                                        <t t-esc="line.name"/>
                                    </td>
                                    <td style="padding: 7px 10px; color: #444;">
                                        <t t-esc="line.document_type or '—'"/>
                                    </td>
                                    <td style="padding: 7px 10px; font-family: monospace;
                                               font-size: 8.5px; color: #333; word-break: break-all;">
                                        <t t-esc="line.sha256_hash or '—'"/>
                                    </td>
                                </tr>
                            </tbody>
                        </table>


                        <div style="margin-top: 28px; border-top: 1px solid #dde3ed;
                                    padding-top: 10px; font-size: 9px; color: #666;
                                    text-align: center;">
                            Documento generado electronicamente · Integridad garantizada por hash SHA-256 y blockchain ·
                            Sistema de Gestion Judicial
                        </div>
                    </div>
                </t>
            </t>
        </template>


        <record id="action_report_judicial_evidence" model="ir.actions.report">
            <field name="name">Reporte de Evidencias</field>
            <field name="model">judicial.case</field>
            <field name="report_type">qweb-pdf</field>
            <field name="report_name">judicial_reports.evidence_report_template</field>
            <field name="report_file">judicial_reports.evidence_report_template</field>
            <field name="print_report_name">'Evidencias - %s' % object.name</field>
        </record>

        <template id="evidence_report_template">
            <t t-call="web.html_container">
                <t t-foreach="evidence_data" t-as="entry">
                    <div style="font-family: 'Helvetica Neue', Helvetica, Arial, sans-serif;
                                color: #2c2c2c; padding: 24px; margin: 0;">

                        <!-- ── Encabezado ── -->
                        <div style="background: #1b2a4a; color: white;
                                    padding: 20px 24px; border-radius: 6px;
                                    margin-bottom: 20px;">
                            <table style="width: 100%; border-collapse: collapse;">
                                <tr>
                                    <td style="vertical-align: middle;">
                                        <div style="font-size: 9px; letter-spacing: 2px;
                                                    text-transform: uppercase; margin-bottom: 4px;
                                                    color: #8aafd0;">
                                            Sistema de Gestion Judicial
                                        </div>
                                        <div style="font-size: 20px; font-weight: 700; letter-spacing: 0.5px; color: white;">
                                            REPORTE DE EVIDENCIAS
                                        </div>
                                        <div style="font-size: 12px; margin-top: 4px; color: #aac4e0;">
                                            Documentos con trazabilidad blockchain verificada
                                        </div>
                                    </td>
                                    <td style="text-align: right; vertical-align: middle;">
                                        <div style="font-size: 22px; font-weight: 800;
                                                    border: 2px solid rgba(255,255,255,0.4);
                                                    padding: 8px 16px; border-radius: 4px;
                                                    display: inline-block; color: white;">
                                            <span t-field="entry['case'].name"/>
                                        </div>
                                        <div style="font-size: 10px; margin-top: 4px; color: #8aafd0;">
                                            Codigo de expediente
                                        </div>
                                    </td>
                                </tr>
                            </table>
                        </div>

                        <table style="width: 100%; border-collapse: collapse; margin-bottom: 20px;">
                            <tr>
                                <td style="width: 50%; vertical-align: top; padding-right: 10px;">
                                    <div style="background: #f7f9fc; border: 1px solid #dde3ed;
                                                border-radius: 6px; padding: 14px;">
                                        <div style="font-size: 10px; font-weight: 700; color: #2d4a7a;
                                                    text-transform: uppercase; letter-spacing: 0.8px;
                                                    border-bottom: 2px solid #2d4a7a;
                                                    padding-bottom: 6px; margin-bottom: 12px;">
                                            Datos del Expediente
                                        </div>
                                        <table style="width: 100%; border-collapse: collapse; font-size: 11px;">
                                            <tr>
                                                <td style="padding: 5px 0; color: #555; width: 38%;">Titulo</td>
                                                <td style="padding: 5px 0; font-weight: 600; color: #1a1a1a;">
                                                    <span t-field="entry['case'].title"/>
                                                </td>
                                            </tr>
                                            <tr style="background: #eef2f8;">
                                                <td style="padding: 5px 6px; color: #555;">Parte procesal</td>
                                                <td style="padding: 5px 6px; font-weight: 600; color: #1a1a1a;">
                                                    <span t-field="entry['case'].partner_id.name"/>
                                                </td>
                                            </tr>
                                            <tr>
                                                <td style="padding: 5px 0; color: #555;">Responsable</td>
                                                <td style="padding: 5px 0; font-weight: 600; color: #1a1a1a;">
                                                    <span t-field="entry['case'].assigned_user_id.name"/>
                                                </td>
                                            </tr>
                                            <tr style="background: #eef2f8;">
                                                <td style="padding: 5px 6px; color: #555;">Estado</td>
                                                <td style="padding: 5px 6px;">
                                                    <span style="background: #2d4a7a; color: white;
                                                                 padding: 2px 10px; border-radius: 12px;
                                                                 font-size: 10px; font-weight: 700;">
                                                        <span t-field="entry['case'].state"/>
                                                    </span>
                                                </td>
                                            </tr>
                                        </table>
                                    </div>
                                </td>

                                <td style="width: 50%; vertical-align: top; padding-left: 10px;">
                                    <div style="background: #f0f7f0; border: 1px solid #c3dfc3;
                                                border-radius: 6px; padding: 14px;">
                                        <div style="font-size: 10px; font-weight: 700; color: #2e7d32;
                                                    text-transform: uppercase; letter-spacing: 0.8px;
                                                    border-bottom: 2px solid #2e7d32;
                                                    padding-bottom: 6px; margin-bottom: 12px;">
                                            Registro Blockchain
                                        </div>
                                        <table style="width: 100%; border-collapse: collapse; font-size: 10px;">
                                            <tr>
                                                <td style="padding: 5px 0; color: #555; width: 38%; vertical-align: top;">
                                                    Hash SHA-256
                                                </td>
                                                <td style="padding: 5px 0; font-family: monospace;
                                                           word-break: break-all; font-size: 8.5px; color: #222;">
                                                    <t t-esc="entry['case'].active_document_hash or '—'"/>
                                                </td>
                                            </tr>
                                            <tr style="background: #e8f5e9;">
                                                <td style="padding: 5px 6px; color: #555; vertical-align: top;">TX Hash</td>
                                                <td style="padding: 5px 6px; font-family: monospace;
                                                           word-break: break-all; font-size: 8.5px; color: #222;">
                                                    <t t-esc="entry['case'].blockchain_tx_hash or '—'"/>
                                                </td>
                                            </tr>
                                            <tr>
                                                <td style="padding: 5px 0; color: #555;">Wallet ancla</td>
                                                <td style="padding: 5px 0; font-family: monospace;
                                                           word-break: break-all; font-size: 8.5px; color: #222;">
                                                    <t t-esc="entry['case'].blockchain_anchor_address or '—'"/>
                                                </td>
                                            </tr>
                                            <tr style="background: #e8f5e9;">
                                                <td style="padding: 5px 6px; color: #555;">Fecha anclaje</td>
                                                <td style="padding: 5px 6px; font-weight: 700; color: #2e7d32; font-size: 11px;">
                                                    <t t-esc="entry['case'].blockchain_anchor_at or '—'"/>
                                                </td>
                                            </tr>
                                        </table>
                                    </div>
                                </td>
                            </tr>
                        </table>


                        <t t-if="entry['case'].description">
                            <div style="background: #fffef5; border-left: 4px solid #f0a500;
                                        padding: 12px 16px; border-radius: 0 6px 6px 0;
                                        margin-bottom: 20px; font-size: 11px;">
                                <div style="font-weight: 700; color: #b37a00; margin-bottom: 6px;
                                            text-transform: uppercase; font-size: 10px; letter-spacing: 0.6px;">
                                    Descripcion del caso
                                </div>
                                <p style="margin: 0; line-height: 1.6; color: #2c2c2c;"
                                   t-esc="entry['case'].description"/>
                            </div>
                        </t>


                        <table style="width: 100%; border-collapse: collapse; margin-bottom: 10px;">
                            <tr>
                                <td style="vertical-align: middle;">
                                    <span style="font-size: 11px; font-weight: 700; color: #1b2a4a;
                                                 text-transform: uppercase; letter-spacing: 0.8px;">
                                        Documentos Marcados como Evidencia Oficial
                                    </span>
                                </td>
                                <t t-if="entry['evidence_docs']">
                                    <td style="text-align: right; vertical-align: middle;">
                                        <span style="background: #2d4a7a; color: white;
                                                     padding: 3px 12px; border-radius: 12px;
                                                     font-size: 10px; font-weight: 700;">
                                            <t t-esc="len(entry['evidence_docs'])"/> documento(s)
                                        </span>
                                    </td>
                                </t>
                            </tr>
                        </table>


                        <t t-if="entry['evidence_docs']">
                            <table style="width: 100%; border-collapse: collapse; font-size: 10px;
                                          border: 1px solid #dde3ed;">
                                <thead>
                                    <tr style="background: #1b2a4a;">
                                        <th style="padding: 9px 10px; text-align: center;
                                                   font-weight: 600; width: 4%; color: white;">#</th>
                                        <th style="padding: 9px 10px; text-align: left;
                                                   font-weight: 600; width: 22%; color: white;">Nombre</th>
                                        <th style="padding: 9px 10px; text-align: left;
                                                   font-weight: 600; width: 12%; color: white;">Tipo</th>
                                        <th style="padding: 9px 10px; text-align: left;
                                                   font-weight: 600; width: 31%; color: white;">Hash SHA-256</th>
                                        <th style="padding: 9px 10px; text-align: left;
                                                   font-weight: 600; width: 31%; color: white;">TX Hash Blockchain</th>
                                    </tr>
                                </thead>
                                <tbody>
                                    <tr t-foreach="entry['evidence_docs']" t-as="doc"
                                        t-attf-style="background: {{ '#f7f9fc' if doc_index % 2 == 0 else 'white' }}; border-bottom: 1px solid #eee;">
                                        <td style="padding: 8px 10px; text-align: center; color: #666; font-weight: 600;">
                                            <t t-esc="doc_index + 1"/>
                                        </td>
                                        <td style="padding: 8px 10px; font-weight: 600; color: #1b2a4a;">
                                            <t t-esc="doc.name"/>
                                        </td>
                                        <td style="padding: 8px 10px;">
                                            <span style="background: #e8edf5; color: #2d4a7a;
                                                         padding: 2px 8px; border-radius: 10px;
                                                         font-size: 9px; font-weight: 600;">
                                                <t t-esc="doc.document_type or '—'"/>
                                            </span>
                                        </td>
                                        <td style="padding: 8px 10px; font-family: monospace;
                                                   font-size: 8px; color: #333;
                                                   word-break: break-all; line-height: 1.4;">
                                            <t t-esc="doc.sha256_hash or '—'"/>
                                        </td>
                                        <td style="padding: 8px 10px; font-family: monospace;
                                                   font-size: 8px; color: #333;
                                                   word-break: break-all; line-height: 1.4;">
                                            <t t-esc="doc.blockchain_tx_hash or '—'"/>
                                        </td>
                                    </tr>
                                </tbody>
                            </table>


                            <div style="margin-top: 12px; background: #e8f5e9;
                                        border: 1px solid #c3dfc3; border-radius: 6px;
                                        padding: 10px 14px; font-size: 10px;">
                                <table style="width: 100%; border-collapse: collapse;">
                                    <tr>
                                        <td style="font-weight: 700; color: #2e7d32;">
                                            Resumen de integridad
                                        </td>
                                        <td style="text-align: right; color: #444;">
                                            Total de evidencias:
                                            <strong style="color: #1b2a4a;">
                                                <t t-esc="len(entry['evidence_docs'])"/>
                                            </strong>
                                        </td>
                                    </tr>
                                </table>
                            </div>
                        </t>

                        <t t-else="">
                            <div style="background: #fafafa; border: 1px dashed #ccc;
                                        border-radius: 6px; padding: 20px;
                                        text-align: center; color: #777; font-size: 11px;">
                                Este expediente no tiene documentos marcados como evidencia oficial.
                            </div>
                        </t>


                        <div style="margin-top: 28px; border-top: 1px solid #dde3ed;
                                    padding-top: 10px; font-size: 9px; color: #666;
                                    text-align: center; line-height: 1.6;">
                            Documento generado electronicamente por el Sistema de Gestion Judicial.<br/>
                            La integridad de los documentos de evidencia esta garantizada mediante
                            hash SHA-256 y anclaje en blockchain.<br/>
                            <strong style="color: #444;">
                                Prohibida su alteracion. Cualquier modificacion invalida la cadena de custodia.
                            </strong>
                        </div>

                    </div>
                </t>
            </t>
        </template>
    </data>
</odoo>