<odoo>
    <data>

        <record id="action_judicial_dashboard_client" model="ir.actions.client">
            <field name="name">Dashboard Judicial</field>
            <field name="tag">judicial_dashboard_client_action</field>
        </record>

        <record id="view_judicial_dashboard_form" model="ir.ui.view">
            <field name="name">judicial.dashboard.form</field>
            <field name="model">judicial.dashboard</field>
            <field name="arch" type="xml">
                <form string="Dashboard Judicial" create="false" edit="false" delete="false">
                    <sheet>
                        <div class="oe_title">
                            <h1>Dashboard Judicial MVP</h1>
                        </div>

                        <!-- Expedientes -->
                        <group string="Expedientes">
                            <group>
                                <field name="total_cases" string="Total expedientes"/>
                                <field name="open_cases" string="Expedientes abiertos"/>
                                <field name="anchored_cases" string="Anclados on-chain"/>
                                <field name="closed_cases" string="Cerrados"/>
                            </group>
                            <group>
                                <field name="draft_cases" string="En borrador"/>
                                <field name="in_process_cases" string="En proceso"/>
                                <field name="cases_this_month" string="Creados este mes"/>
                            </group>
                        </group>

                        <!-- Documentos -->
                        <group string="Documentos">
                            <group>
                                <field name="total_documents" string="Total documentos"/>
                                <field name="official_evidence_count" string="Evidencias oficiales"/>
                                <field name="documents_with_hash" string="Con hash SHA-256"/>
                            </group>
                        </group>

                        <!-- Blockchain -->
                        <group string="Blockchain">
                            <group>
                                <field name="total_anchors" string="Total anclajes"/>
                                <field name="confirmed_anchors" string="Confirmados"/>
                                <field name="failed_anchors" string="Fallidos"/>
                                <field name="pending_anchors" string="Pendientes"/>
                            </group>
                            <group>
                                <field name="anchor_success_rate" string="Tasa de éxito (%)" widget="float"/>
                                <field name="anchors_today" string="Anclajes hoy"/>
                                <field name="anchors_this_week" string="Anclajes esta semana"/>
                            </group>
                        </group>
                    </sheet>
                </form>
            </field>
        </record>

    </data>
</odoo>
