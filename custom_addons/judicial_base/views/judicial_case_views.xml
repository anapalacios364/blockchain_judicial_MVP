        <record id="view_judicial_case_form" model="ir.ui.view">
            <field name="name">judicial.case.form</field>
            <field name="model">judicial.case</field>
            <field name="arch" type="xml">
                <form string="Expediente judicial">
                    <header>
                        <button name="action_start" type="object" string="Iniciar" class="btn-primary" invisible="state != 'draft'"/>
                        <button name="action_anchor_blockchain" type="object" string="Anclar en blockchain" class="btn-primary" invisible="not can_anchor or state == 'anchored'"/>
                        <button name="action_close" type="object" string="Cerrar" invisible="state == 'closed'"/>
                        <field name="state" widget="statusbar" statusbar_visible="draft,in_process,anchored,closed"/>
                    </header>
                    <sheet>
                        <div class="oe_title">
                            <h1>
                                <field name="name" readonly="1"/>
                            </h1>
                            <h2>
                                <field name="title"/>
                            </h2>
                        </div>
                        <group>
                            <group>
                                <field name="partner_id"/>
                                <field name="assigned_user_id"/>
                                <field name="active_document_id"/>
                                <field name="document_count" readonly="1"/>
                            </group>
                            <group>
                                <field name="active_document_hash" readonly="1"/>
                                <field name="blockchain_tx_hash" readonly="1"/>
                                <field name="blockchain_case_id" readonly="1"/>
                                <field name="blockchain_anchor_address" readonly="1"/>
                                <field name="blockchain_anchor_at" readonly="1"/>
                            </group>
                        </group>
                        <notebook>
                            <page string="Descripción">
                                <field name="description"/>
                            </page>
                            <page string="Documentos">
                                <field name="document_ids" context="{'default_case_id': id}">
                                    <list editable="bottom">
                                        <field name="name"/>
                                        <field name="document_type"/>
                                        <field name="is_official_evidence"/>
                                        <field name="sha256_hash" readonly="1"/>
                                        <field name="blockchain_tx_hash" readonly="1"/>
                                    </list>
                                </field>
                                <button name="action_view_documents" type="object" string="Abrir documentos" class="btn-secondary mt-2"/>
                            </page>
                            <page string="Seguimiento">
                                <field name="message_ids" widget="mail_thread"/>
                            </page>
                        </notebook>
                    </sheet>
                    <chatter/>
                </form>
            </field>
        </record>

        <record id="action_judicial_case" model="ir.actions.act_window">
            <field name="name">Expedientes</field>
            <field name="res_model">judicial.case</field>
            <field name="view_mode">list,form</field>
<!--            <field name="search_view_id" ref="view_judicial_case_search"/>-->
        </record>
    </data>
